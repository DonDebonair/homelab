[%- import '_volumes.j2' as vol with context -%]
services:
  technitium-dns:
    image: [[ app.image ]]:[[ app.version ]]
    container_name: technitium-dns
    hostname: technitium-dns
    networks:
      macvlan:
        ipv4_address: [[ host.data.dns_ip ]]
[% if host.data.dns_console_via_caddy_labels %]
      caddy-internal:
[% endif %]
    environment:
      - DNS_SERVER_DOMAIN=[[ host.data.dns_console_subdomain ]].[[ host.data.domain ]]
      - DNS_SERVER_ADMIN_PASSWORD_FILE=/run/secrets/ADMIN_PASSWORD
      - DNS_SERVER_FORWARDERS=[[ dns_forwarders ]]
      - DNS_SERVER_RECURSION=AllowOnlyForPrivateNetworks
      - DNS_SERVER_ENABLE_BLOCKING=true
      - DNS_SERVER_BLOCK_LIST_URLS=[[ dns_blocklist_urls ]]
      - DNS_SERVER_LOG_FOLDER_PATH=/var/log/technitium/dns
      - DNS_SERVER_LOG_USING_LOCAL_TIME=true
      - DNS_SERVER_SSO_ENABLED=true
      - DNS_SERVER_SSO_AUTHORITY=https://auth.[[ host.data.domain ]]
      - DNS_SERVER_SSO_CLIENT_ID=technitium-dns
      - DNS_SERVER_SSO_CLIENT_SECRET_FILE=/run/secrets/SSO_CLIENT_SECRET
      - DNS_SERVER_SSO_SCOPES=openid,groups,profile,email
      - DNS_SERVER_SSO_ALLOW_SIGNUP=true
    volumes:[[ vol.service_volumes(app) ]]
    restart: unless-stopped
    sysctls:
      - net.ipv4.ip_local_port_range=1024 65535
[% if host.data.dns_console_via_caddy_labels %]
    labels:
      caddy_internal: [[ host.data.dns_console_domains | join(', ') ]]
      caddy_internal.reverse_proxy: "{{upstreams 5380}}"
      # Homepage discovers this (docker_vm-primary) instance via the docker
      # socket. The widget must use the canonical console URL over HTTPS: hitting
      # the container directly (http://technitium-dns:5380) makes Technitium
      # 301-redirect to its configured https domain, and homepage's HTTP agent
      # refuses to follow http->https (ERR_INVALID_PROTOCOL). caddy terminates
      # TLS with a valid cert and reverse-proxies to :5380; the API token in the
      # query bypasses the console's Authelia SSO. Token is scoped to
      # Dashboard->View only (the widget calls dashboard/stats/get).
      homepage.group: Admin
      homepage.name: Technitium
      homepage.icon: technitium
      homepage.href: https://[[ host.data.dns_console_subdomain ]].[[ host.data.domain ]]
      homepage.widget.type: technitium
      homepage.widget.url: https://[[ host.data.dns_console_subdomain ]].[[ host.data.domain ]]
      homepage.widget.key: [[ technitium_api_token ]]
      homepage.weight: 1500
[% endif %]
    extra_hosts:
      auth.[[ host.data.domain ]]: "[[ host.data.external_reverse_proxy_ip ]]"

networks:
  macvlan:
    external: true
[% if host.data.dns_console_via_caddy_labels %]
  caddy-internal:
    external: true
[% endif %]
[[ vol.top_level_volumes(app) ]]
