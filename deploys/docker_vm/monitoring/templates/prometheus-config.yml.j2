scrape_configs:
  - job_name: 'prometheus'
    scrape_interval: 10s
    static_configs:
      - targets: ['prometheus:9090']
  - job_name: 'nodeexporter'
    scrape_interval: 5s
    static_configs:
      # docker_vm's exporter runs with network_mode: host (see prometheus.yaml.j2),
      # so it binds the host's :9100 rather than a monitoring-bridge IP.
      - targets: ['[[ host.data.docker_vm_ip ]]:9100']
        labels:
          instance: docker_vm
      # Native (apt) node-exporters on the non-Docker Debian hosts -- installed
      # via deploys/common/node_exporter -- scraped over the LAN on :9100.
      - targets: ['[[ host.data.proxmox_ip ]]:9100']
        labels:
          instance: proxmox_host
      - targets: ['[[ host.data.pbs_ip ]]:9100']
        labels:
          instance: pbs_vm
      - targets: ['[[ host.data.postgres_lxc_ip ]]:9100']
        labels:
          instance: postgres_lxc
  - job_name: 'snmp'
    scrape_interval: 5s
    static_configs:
      - targets: ['[[ host.data.nas_ip ]]']
    metrics_path: /snmp
    params:
      module: [synology]
      auth: [snmpv3]
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - source_labels: [__param_target]
        regex: (.*)
        replacement: snmp-exporter:9116
        target_label: __address__
  - job_name: 'garage'
    scrape_interval: 15s
    # Garage exposes Prometheus metrics on its admin API port (3903). /metrics is
    # unauthenticated here (no metrics_token in garage.toml) -- same as every other
    # target on the internal bridge. Reached over the `monitoring` network, which the
    # garage container joins for this (deploys/docker_vm/apps/templates/garage.yaml.j2).
    metrics_path: /metrics
    static_configs:
      - targets: ['garage:3903']
        labels:
          instance: garage
  - job_name: 'cadvisor'
    scrape_interval: 5s
    static_configs:
      - targets: ['cadvisor:8080']
        labels:
          instance: docker_vm
  # cAdvisor for the containers still running on the NAS. It publishes host port
  # 8098 there; the docker_vm reaches the NAS over the LAN. instance=nas so its
  # metrics are distinguishable from the local cadvisor above.
  - job_name: 'cadvisor-nas'
    scrape_interval: 5s
    static_configs:
      - targets: ['[[ host.data.nas_ip ]]:8098']
        labels:
          instance: nas
