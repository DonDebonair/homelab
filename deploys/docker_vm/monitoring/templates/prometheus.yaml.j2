[%- import '_volumes.j2' as vol with context -%]
services:
  prometheus:
    container_name: prometheus
    image: [[ app.image ]]:[[ app.version ]]
    command:
      - '--storage.tsdb.retention.time=60d'
      - '--storage.tsdb.path=/prometheus'
      - '--config.file=/etc/prometheus/prometheus.yml'
    networks:
      - caddy-internal
      - monitoring
    volumes:
      - prometheus-data:/prometheus
      - [[ host.data.docker_volumes_base ]]/prometheus/config:/etc/prometheus:ro
    labels:
      caddy_internal: [[ app.domain ]]
      caddy_internal.reverse_proxy: "{{upstreams 9090}}"
      # Prometheus has no auth of its own -> gate it behind Authelia.
      caddy_internal.import: secure *
      homepage.group: Monitoring
      homepage.name: Prometheus
      homepage.icon: prometheus
      homepage.href: https://[[ app.domain ]]
      # Widget talks to the container directly (prometheus:9090), bypassing the
      # `import secure` forward-auth above -- the public URL would bounce the
      # widget's API call to the Authelia login page. Prometheus needs no auth.
      homepage.widget.type: prometheus
      homepage.widget.url: http://prometheus:9090
      homepage.weight: 2000
    expose:
      - 9090
    restart: unless-stopped

  node-exporter:
    container_name: node-exporter
    image: prom/node-exporter:v1.12.0
    command:
      # Run node-exporter's default collector set -- same as the apt-installed
      # exporters on the other hosts, so all four report a consistent set of
      # metrics and populate the Node Exporter Full dashboard identically.
      - --path.rootfs=/host
      # network_mode: host exposes every container veth / docker bridge as a NIC
      # (~48 devices). Keep only the real host uplinks (ens18, macvlan-shim, lo)
      # to avoid a per-container time-series explosion -- this is the one place
      # docker_vm differs from the other (non-Docker) hosts. netdev (traffic
      # counters) and netclass (link state/info) are separate collectors with
      # separate exclude flags, so filter both with the same pattern.
      - --collector.netdev.device-exclude=^(veth.*|br-[0-9a-f]+|docker[0-9]+)$
      - --collector.netclass.ignored-devices=^(veth.*|br-[0-9a-f]+|docker[0-9]+)$
    # Host PID + network namespaces plus a bind of the host root give every
    # collector the host's view: pid/net sharing makes the container's own /proc
    # & /sys host-correct (so cpu/mem/hwmon/netdev report the host), and
    # --path.rootfs=/host matches the /host bind so the filesystem collector
    # enumerates the host's mountpoints (stripping the /host prefix from names).
    # network_mode: host is required for netdev to see the host NICs -- it takes
    # the exporter off the monitoring bridge, so Prometheus scrapes it by host IP
    # (see the nodeexporter job in prometheus-config.yml.j2).
    pid: host
    network_mode: host
    volumes:
      - /:/host:ro,rslave
    restart: unless-stopped

  snmp-exporter:
    container_name: snmp-exporter
    image: prom/snmp-exporter:v0.30.1
    command:
      - '--config.file=/etc/snmp_exporter/snmp.yml'
    networks:
      - monitoring
    volumes:
      - [[ host.data.docker_volumes_base ]]/snmp:/etc/snmp_exporter:ro
    restart: unless-stopped

  cadvisor:
    container_name: cadvisor
    image: gcr.io/cadvisor/cadvisor:v0.55.1
    command:
      - '--docker_only=true'
    networks:
      - monitoring
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:ro
      - /sys:/sys:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
    restart: unless-stopped

networks:
  caddy-internal:
    external: true
  monitoring:
    external: true
[[ vol.top_level_volumes(app) ]]
