[%- import '_volumes.j2' as vol with context -%]
services:
  grafana:
    container_name: grafana
    image: [[ app.image ]]:[[ app.version ]]
    environment:
      GF_SERVER_ROOT_URL: https://[[ app.domain ]]
      # Self-authenticated via Authelia OIDC (no caddy forward-auth).
      GF_AUTH_GENERIC_OAUTH_ENABLED: true
      GF_AUTH_GENERIC_OAUTH_NAME: Authelia
      GF_AUTH_GENERIC_OAUTH_CLIENT_ID: grafana
      GF_AUTH_GENERIC_OAUTH_CLIENT_SECRET: [[ grafana_oidc_client_secret ]]
      GF_AUTH_GENERIC_OAUTH_SCOPES: openid profile email groups
      GF_AUTH_GENERIC_OAUTH_EMPTY_SCOPES: false
      GF_AUTH_GENERIC_OAUTH_AUTH_URL: https://auth.[[ host.data.domain ]]/api/oidc/authorization
      GF_AUTH_GENERIC_OAUTH_TOKEN_URL: https://auth.[[ host.data.domain ]]/api/oidc/token
      GF_AUTH_GENERIC_OAUTH_API_URL: https://auth.[[ host.data.domain ]]/api/oidc/userinfo
      GF_AUTH_GENERIC_OAUTH_LOGIN_ATTRIBUTE_PATH: preferred_username
      GF_AUTH_GENERIC_OAUTH_GROUPS_ATTRIBUTE_PATH: groups
      GF_AUTH_GENERIC_OAUTH_NAME_ATTRIBUTE_PATH: name
      GF_AUTH_GENERIC_OAUTH_USE_PKCE: true
      GF_AUTH_GENERIC_OAUTH_ROLE_ATTRIBUTE_PATH: contains(groups, 'administrators') && 'Admin' || 'Viewer'
      GF_AUTH_GENERIC_OAUTH_AUTO_LOGIN: true
      # DB on the postgres_lxc over the LAN; dashboards/users/datasources live here.
      GF_DATABASE_TYPE: postgres
      GF_DATABASE_HOST: [[ host.data.postgres_lxc_ip ]]:5432
      GF_DATABASE_NAME: grafana
      GF_DATABASE_USER: grafana
      GF_DATABASE_PASSWORD: [[ grafana_db_password ]]
      GF_DATABASE_SSL_MODE: disable
      GF_SECURITY_DISABLE_INITIAL_ADMIN_CREATION: true
      TZ: Europe/Amsterdam
    networks:
      # caddy-internal: reverse proxy. monitoring: reach prometheus/loki by name
      # (migrated datasource URLs http://prometheus:9090 / http://loki:3100).
      - caddy-internal
      - monitoring
    volumes:[[ vol.service_volumes(app) ]]
    labels:
      caddy_internal: [[ app.domain ]]
      caddy_internal.reverse_proxy: "{{upstreams 3000}}"
      homepage.group: Monitoring
      homepage.name: Grafana
      homepage.icon: grafana
      homepage.href: https://[[ app.domain ]]
      homepage.weight: 1000
    expose:
      - 3000
    restart: unless-stopped

networks:
  caddy-internal:
    external: true
  monitoring:
    external: true
[[ vol.top_level_volumes(app) ]]
