[%- import '_volumes.j2' as vol with context -%]
services:
  cwa:
    container_name: cwa
    image: [[ app.image ]]:[[ app.version ]]
    volumes:[[ vol.service_volumes(app) ]]
    environment:
      TZ: Europe/Amsterdam
      # The calibre library is on the NAS over NFS (maps by numeric id). Run as
      # the docker_vm docker user (PUID 2000) with PGID 100 -- the NAS `users`
      # group, `dockervm`'s primary group -- matching qbittorrent/sabnzbd so
      # writes to the shared /volume1/entertainment tree work.
      PUID: [[ host.data.docker_uid ]]
      PGID: 100
      # metadata.db (library) + app.db (config) are SQLite on a network share.
      # This CWA switch disables WAL on both, skips recursive chowns that fail on
      # network filesystems, and uses polling watchers instead of inotify. See
      # the CWA README -> "Deploying on Network Shares (NFS/SMB)".
      NETWORK_SHARE_MODE: "true"
    networks:
      - caddy-internal
    labels:
      caddy_internal: [[ app.domain ]]
      caddy_internal.reverse_proxy: "{{upstreams 8083}}"
      # No `import secure` here: CWA gates itself with native OIDC against Authelia
      # (client `calibre-web` in proxies/vars.py; provider set up once in CWA's
      # admin UI -- see docs/plans/cwa-migration.md). Standard login is disabled in
      # CWA so OIDC is the sole gate, mapping SSO identities to CWA users instead of
      # treating everyone past a forward-auth gate the same.
      homepage.group: Entertainment
      homepage.name: Calibre-Web Automated
      homepage.icon: calibre-web
      homepage.href: https://[[ app.domain ]]
      # Widget talks to the container directly (cwa:8083) with a dedicated
      # read-only CWA user over basic auth -- the public URL redirects to the
      # OIDC login, which the widget's basic-auth call can't complete.
      homepage.widget.type: calibreweb
      homepage.widget.url: http://cwa:8083
      homepage.widget.username: [[ cwa_widget_username ]]
      homepage.widget.password: [[ cwa_widget_password ]]
      homepage.weight: 310
    expose:
      - 8083
    restart: unless-stopped

networks:
  caddy-internal:
    external: true
[[ vol.top_level_volumes(app) ]]
