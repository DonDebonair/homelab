[%- import '_volumes.j2' as vol with context -%]
services:
  n8n:
    container_name: n8n
    image: [[ app.image ]]:[[ app.version ]]
    networks:
      - caddy-internal
    volumes:[[ vol.service_volumes(app) ]]
    environment:
      # DB on the postgres_lxc over the LAN (like miniflux/forgejo/paperless).
      DB_TYPE: postgresdb
      DB_POSTGRESDB_HOST: [[ host.data.postgres_lxc_ip ]]
      DB_POSTGRESDB_PORT: 5432
      DB_POSTGRESDB_DATABASE: n8n
      DB_POSTGRESDB_USER: n8n
      DB_POSTGRESDB_PASSWORD: [[ n8n_db_password ]]
      GENERIC_TIMEZONE: Europe/Amsterdam
      # The encryption key is NOT set here on purpose -- n8n reads it from the
      # migrated /home/node/.n8n/config so stored credentials stay decryptable.
      WEBHOOK_URL: https://[[ app.domain ]]/
    labels:
      caddy_internal: [[ app.domain ]]
      caddy_internal.reverse_proxy: "{{upstreams 5678}}"
      # No `import secure`: n8n has its own user management and its webhook
      # endpoints must be reachable without Authelia SSO (matches the NAS).
      homepage.group: Automation
      homepage.name: n8n
      homepage.icon: n8n
      homepage.href: https://[[ app.domain ]]
      homepage.weight: 1000
    expose:
      - 5678
    restart: unless-stopped

networks:
  caddy-internal:
    external: true
[[ vol.top_level_volumes(app) ]]
