[%- import '_volumes.j2' as vol with context -%]
services:
  seerr:
    container_name: seerr
    image: [[ app.image ]]:[[ app.version ]]
    # The image ships no init process (removed upstream), so an unreaped zombie
    # would otherwise accumulate -- docker's tini via `init: true` reaps them.
    init: true
    volumes:[[ vol.service_volumes(app) ]]
    environment:
      TZ: Europe/Amsterdam
      LOG_LEVEL: info
      PORT: 5055
    networks:
      - caddy-internal
    labels:
      # Seerr self-authenticates via Plex login, so it is NOT behind the Authelia
      # forward-auth layer (no `import secure`) -- users need the request UI
      # reachable to sign in with Plex.
      caddy_internal: [[ app.domain ]]
      caddy_internal.reverse_proxy: "{{upstreams 5055}}"
      homepage.group: Entertainment
      homepage.name: Seerr
      homepage.icon: overseerr
      homepage.href: https://[[ app.domain ]]
      # Seerr keeps Overseerr's /api/v1 surface, so the overseerr widget works.
      homepage.widget.type: overseerr
      homepage.widget.url: https://[[ app.domain ]]
      # Seerr API key (Settings -> General), generated at first-run setup and
      # stored in 1Password (fresh install -- not carried over from overseerr).
      homepage.widget.key: [[ seerr_api_token ]]
      homepage.weight: 100
    expose:
      - 5055
    restart: unless-stopped

networks:
  caddy-internal:
    external: true
[[ vol.top_level_volumes(app) ]]
