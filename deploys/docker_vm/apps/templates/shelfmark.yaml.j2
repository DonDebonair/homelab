[%- import '_volumes.j2' as vol with context -%]
services:
  shelfmark:
    container_name: shelfmark
    image: [[ app.image ]]:[[ app.version ]]
    volumes:[[ vol.service_volumes(app) ]]
    environment:
      TZ: Europe/Amsterdam
      # PUID 2000 / PGID 100 matches BookOrbit (see bookorbit.yaml.j2): Shelfmark
      # writes completed downloads into BookOrbit's ingest bind and BookOrbit
      # (same uid) stages + finalizes them, so ownership must line up.
      PUID: [[ host.data.docker_uid ]]
      PGID: 100
      # Where completed downloads are written. Points at BookOrbit's Book Dock
      # ingest bind (mounted at /ingest below) so books flow into BookOrbit's
      # ingest (replacing CWA).
      INGEST_DIR: /ingest
      # OIDC is configured once in Shelfmark's UI (Settings -> Security -> OIDC)
      # and persisted on the /config volume -- nothing here. To make OIDC the
      # sole gate after it's verified, uncomment (see docs/plans/shelfmark.md):
      # DISABLE_LOCAL_AUTH: "true"
      HIDE_LOCAL_AUTH: "true"    # Hide the local login form
      DISABLE_LOCAL_AUTH: "true" # Disable username/password login
      OIDC_AUTO_REDIRECT: "true"
    networks:
      - caddy-internal
    labels:
      caddy_internal: [[ app.domain ]]
      caddy_internal.reverse_proxy: "{{upstreams 8084}}"
      # No `import secure`: Shelfmark gates itself with native OIDC against
      # Authelia (client `shelfmark` in proxies/vars.py; provider set up once in
      # Shelfmark's admin UI -- see docs/plans/shelfmark.md). This maps SSO
      # identities to Shelfmark users/requests instead of a blanket forward-auth.
      homepage.group: Entertainment
      homepage.name: Shelfmark
      homepage.icon: shelfmark.png
      homepage.href: https://[[ app.domain ]]
      homepage.weight: 320
    expose:
      - 8084
    restart: unless-stopped

networks:
  caddy-internal:
    external: true
[[ vol.top_level_volumes(app) ]]
