[%- import '_volumes.j2' as vol with context -%]
services:
  sabnzbd:
    container_name: sabnzbd
    image: [[ app.image ]]:[[ app.version ]]
    volumes:[[ vol.service_volumes(app) ]]
    environment:
      TZ: Europe/Amsterdam
      # Run as the docker_vm docker user (PUID 2000). The usenet download area
      # lives on the NAS and is shared with the *arr stack over NFS; the NAS has
      # a matching `dockervm` account pinned to uid 2000 (see deploys/nas/users)
      # granted Read&Write on the folder, so sabnzbd can write completed
      # downloads over NFS (which maps by numeric id). PGID is 100 -- the NAS
      # `users` group, `dockervm`'s primary group.
      PUID: [[ host.data.docker_uid ]]
      PGID: 100
    networks:
      - caddy-internal
    labels:
      caddy_internal: [[ app.domain ]]
      caddy_internal.reverse_proxy: "{{upstreams 8080}}"
      caddy_internal.import: secure *
      homepage.group: Downloaders
      homepage.name: SABnzbd
      homepage.icon: sabnzbd
      homepage.href: https://[[ app.domain ]]
      homepage.widget.type: sabnzbd
      homepage.widget.url: https://[[ app.domain ]]
      # sabnzbd API key -- resolved from 1Password at render time.
      homepage.widget.key: [[ sabnzbd_api_token ]]
      homepage.weight: 1000
    expose:
      - 8080
    restart: unless-stopped

networks:
  caddy-internal:
    external: true
[[ vol.top_level_volumes(app) ]]
