[%- import '_volumes.j2' as vol with context -%]
services:
  portainer:
    container_name: portainer
    image: [[ app.image ]]:[[ app.version ]]
    volumes:[[ vol.service_volumes(app) ]]
    # Pin the DNS upstream. Portainer resolves an external hostname at runtime (the
    # OIDC token exchange to auth.dv.zone); affine pins this for the same reason. On
    # a user-defined network Docker still serves 127.0.0.11 for service discovery
    # and forwards external queries here, so this only fixes the upstream --
    # instead of snapshotting whatever /etc/resolv.conf held at container-create
    # time. That snapshot is racy: if the container starts before dhcpcd/the DNS
    # shim settle the resolver, it captures a stale upstream and every OIDC login
    # fails with "server misbehaving" until a restart.
    dns:
      - [[ host.data.dns_ip ]]
    networks:
      - caddy-internal
    environment:
      # Shared secret so the server authenticates to remote agents (the NAS
      # agent). Must match AGENT_SECRET on every agent (deploys/nas/docker).
      AGENT_SECRET: [[ portainer_agent_secret ]]
    labels:
      caddy_internal: [[ app.domain ]]
      caddy_internal.reverse_proxy: "{{upstreams 9000}}"
      homepage.group: Admin
      homepage.name: Portainer
      homepage.icon: portainer
      homepage.href: https://[[ app.domain ]]
      homepage.widget.type: portainer
      homepage.widget.url: https://[[ app.domain ]]
      homepage.widget.key: [[ portainer_api_token ]]
      homepage.widget.env: 2
      homepage.weight: 2000
    expose:
      - 9000
    restart: unless-stopped

networks:
  caddy-internal:
    external: true
[[ vol.top_level_volumes(app) ]]
