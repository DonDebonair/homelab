[%- import '_volumes.j2' as vol with context -%]
services:
  caddy-external:
    image: caddy-custom:[[ caddy_version ]]
    container_name: caddy-external
    environment:
      - CADDY_INGRESS_NETWORKS=caddy-external
      - CADDY_DOCKER_LABEL_PREFIX=caddy_external
    networks:
      macvlan:
        ipv4_address: [[ host.data.external_reverse_proxy_ip ]]
      caddy-external:
      authelia:
      tunnel:
    volumes:[[ vol.service_volumes(app) ]]
    restart: unless-stopped
    labels:
      caddy_external_0.email: [[ host.data.email ]]
      caddy_external_0.acme_dns: cloudflare [[ cloudflare_api_token ]]
      caddy_external_90: (trusted_proxy_list)
      caddy_external_90.trusted_proxies: 172.0.0.0/8 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22
      caddy_external_91: (secure)
      caddy_external_91.forward_auth: '{args[0]} authelia:9091'
      caddy_external_91.forward_auth.uri: /api/verify?rd=https://auth.dv.zone
      caddy_external_91.forward_auth.copy_headers: Remote-User Remote-Groups Remote-Name Remote-Email
      caddy_external_91.forward_auth.import: trusted_proxy_list
    dns:
      - 1.1.1.1
      - 1.0.0.1

networks:
  caddy-external:
    external: true
  macvlan:
    external: true
  authelia:
    external: true
  tunnel:
    external: true
[[ vol.top_level_volumes(app) ]]
